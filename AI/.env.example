# LLM provider: openai, gemini, anthropic, custom
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Set the API key for the provider you use.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional LLM settings
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=1500
LLM_TIMEOUT_SECONDS=30

# Optional database / RAG settings
# Set this to the real SQLite product DB if AI should resolve barcode/report-only requests.
# Leave empty to use only the in-memory seed products.
FOOD_CHATBOT_DB_PATH=
RAG_DOCS_DIR=app/knowledge
CHROMA_DB_DIR=app/chroma_db
EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
