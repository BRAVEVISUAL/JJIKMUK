<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutChatHeader"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#F1FBEA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnChatBack"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="뒤로가기"
            android:padding="0dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/tvChatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="포기 블루베리 맛.."
            android:textColor="#124928"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/btnChatBack"
            app:layout_constraintEnd_toStartOf="@id/btnMenu"
            app:layout_constraintStart_toEndOf="@id/btnChatBack"
            app:layout_constraintTop_toTopOf="@id/btnChatBack" />



        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="24dp"
            android:background="@android:color/transparent"
            android:contentDescription="메뉴 열기"
            android:src="@drawable/ic_home_menu"
            app:layout_constraintBottom_toBottomOf="@id/btnChatBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnChatBack"
            tools:ignore="TouchTargetSizeCheck" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="92dp"
        android:contentDescription="채팅 본문"
        app:layout_constraintBottom_toTopOf="@id/layoutChatInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutChatHeader"
        tools:listitem="@layout/item_chat_message_bot" />

    <LinearLayout
        android:id="@+id/layoutChatInput"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_input_box"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnChatPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_camera_circle"
            android:contentDescription="추가"
            android:scaleType="centerInside"
            android:src="@drawable/ic_home_plus"
            tools:ignore="TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:hint="메시지를 입력하세요"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:paddingStart="12dp"
            android:singleLine="true"
            android:textColor="#111111"
            android:textColorHint="#9E9E9E"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="음성 검색"
            android:src="@drawable/ic_home_mic"
            tools:ignore="TouchTargetSizeCheck"/>

        <ImageButton
            android:id="@+id/btnChatSend"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="텍스트 보내기"
            android:src="@drawable/ic_home_send"
            tools:ignore="TouchTargetSizeCheck" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>