<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="92dp"
    android:background="@drawable/bg_bottom_nav"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="홈"
            android:src="@drawable/ic_nav_home" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Home"
            android:textColor="@color/jjikmuk_black"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navDiet"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="식단"
            android:src="@drawable/ic_nav_diet" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Diet"
            android:textColor="@color/jjikmuk_black"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/navCamera"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_gravity="top"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_camera_circle"
        android:contentDescription="사진 검색"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_nav_camera"
        android:translationY="-15dp" />

    <LinearLayout
        android:id="@+id/navHistory"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="기록"
            android:src="@drawable/ic_nav_history" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="History"
            android:textColor="@color/jjikmuk_black"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navMy"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="마이페이지"
            android:src="@drawable/ic_nav_my" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="MY"
            android:textColor="@color/jjikmuk_black"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>