<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutRecommendBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_recommend"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <View
        android:id="@+id/swipebar"
        android:layout_width="36dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <TextView
        android:id="@+id/tvRecommendSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="6dp"
        android:gravity="center"
        android:text="원하시는 상품을 선택해주세요"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecommendProducts"
        android:layout_width="344dp"
        android:layout_gravity="center_horizontal"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        tools:itemCount="2"
        tools:listitem="@layout/item_recommend_product" />

    <TextView
        android:id="@+id/btnMoreProducts"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_more_button_yellow"
        android:gravity="center"
        android:text="MORE →"
        android:textColor="#111111"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
