<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutRecommendProductItem"
    android:layout_width="match_parent"
    android:layout_height="144dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_recommend_product_card"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:id="@+id/layoutProductImageBox"
        android:layout_width="92dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_recommend_product_card"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="상품 이미지"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvProductCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="18dp"
        android:textColor="#9A9A9A"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/layoutProductImageBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="해태제과" />

    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="18dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#111111"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/layoutProductImageBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvProductCategory"
        tools:text="해태 포키 블루베리" />

    <LinearLayout
        android:id="@+id/layoutProductTags"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/layoutProductImageBox"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvAllergyTag1"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/bg_recommend_tag"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#E84242"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="🥛 우유" />

        <TextView
            android:id="@+id/tvAllergyTag2"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_recommend_tag"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#E84242"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="🥜 땅콩" />

    </LinearLayout>
    <ImageButton
        android:id="@+id/btnProductFavorite"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="즐겨찾기"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_heart_filled"
        android:translationZ="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>