<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">


    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="메뉴 열기"
        android:src="@drawable/ic_home_chatmenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="TouchTargetSizeCheck" />

    <FrameLayout
        android:id="@+id/layoutSelectedProfiles"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:layout_marginEnd="20dp"
        android:clickable="true"
        android:contentDescription="스캔 대상 설정 열기"
        android:translationY="-8dp"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnMenu"
        tools:ignore="TouchTargetSizeCheck">

        <ImageView
            android:id="@+id/ivSelectedProfilePreview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/bg_profile_circle"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

    </FrameLayout>

<!--    <TextView-->
<!--        android:id="@+id/tvLogo"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="64dp"-->
<!--        android:layout_marginTop="102dp"-->
<!--        android:gravity="center"-->
<!--        android:text="JJIKMUK"-->
<!--        android:textColor="@color/jjikmuk_green"-->
<!--        android:textSize="32sp"-->
<!--        android:textStyle="bold"-->
<!--        app:layout_constraintEnd_toEndOf="parent"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintTop_toBottomOf="@id/btnMenu" />-->

    <com.coworker.jjikmuk.feature.home.AnimatedJjikmukIconView
        android:id="@+id/tvLogo"
        android:layout_width="89dp"
        android:layout_height="89dp"
        android:layout_marginTop="90dp"
        android:contentDescription="JJIKMUK"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnMenu" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="오늘은 어떤 음식을 찍어 볼까요?"
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLogo" />

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_input_box"
        android:elevation="8dp"
        android:outlineAmbientShadowColor="@color/jjikmuk_light_green"
        android:outlineSpotShadowColor="@color/jjikmuk_dark_green"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <ImageButton
            android:id="@+id/btnPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_camera_circle"
            android:contentDescription="추가"
            android:scaleType="centerInside"
            android:src="@drawable/ic_home_plus"
            tools:ignore="TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/etHomeMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:hint="메시지를 입력하세요"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:paddingStart="12dp"
            android:singleLine="true"
            android:textColor="#111111"
            android:textColorHint="#9E9E9E"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="음성 검색"
            android:src="@drawable/ic_home_mic"
            tools:ignore="TouchTargetSizeCheck" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="텍스트 보내기"
            android:src="@drawable/ic_home_send"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <include
        android:id="@+id/layoutBottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="92dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>