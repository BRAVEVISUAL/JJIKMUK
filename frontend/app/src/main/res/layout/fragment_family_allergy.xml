<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="48dp"
        android:paddingEnd="24dp"
        android:paddingBottom="48dp">

        <ImageButton
            android:id="@+id/btnFamilyAllergyBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:contentDescription="뒤로가기"
            android:src="@drawable/ic_back" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_profile_circle"
            android:padding="18dp"
            android:src="@drawable/ic_history_likes" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="가족 알레르기 관리"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="식품을 스캔할 때 가족 구성원 모두의\n알레르기 위험 요소를 한 번에 검사해 드려요."
            android:textColor="#6B7280"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvFamilyMemberCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:textColor="#8B95A1"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="가족 구성원 (3명)" />

        <LinearLayout
            android:id="@+id/layoutFamilyMemberList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_upload_option_border"
            android:gravity="center"
            android:text="가족 구성원 추가하기"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
